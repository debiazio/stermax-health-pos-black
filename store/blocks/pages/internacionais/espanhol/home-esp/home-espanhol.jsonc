{
  "store.custom#home-espanhol": {
    "parent": {
      "header": "header#empty",
      "footer": "footer#empty"
    },
    "blocks": [
      "sticky-layout#header-esp",
      "list-context.image-list#carrossel-home-desktop-esp",
      "responsive-layout.desktop#banner-personas-esp",
      "responsive-layout.mobile#banner-personas-esp",
      "flex-layout.row#linha-line-esp",
      "__fold__",
      // "flex-layout.row#shelf-esp",
      "responsive-layout.mobile#deals-mobile-esp",
      "flex-layout.row#deals-esp",
      "flex-layout.row#banner-nao-comprometa-saude-esp",
      "flex-layout.row#tipos-autoclaves-home-esp",
      "flex-layout.row#linha-line-esp",
      // "flex-layout.row#shelf-acessorios-esp",
      "flex-layout.row#ultima-section-esp",
      "responsive-layout.desktop#footer-esp",
      "responsive-layout.mobile#footer-esp"
    ]
  },
  "list-context.image-list#carrossel-home-desktop-esp": {
    "children": [
      "slider-layout#carrossel-home-desktop-esp"
    ],
    "props": {
      "fullWidth": true,
      "height": 486,
      "width": 1300,
      "maxWidth": 1300,
      "preload": true,
      "images": [
        {
          "image": "assets/home/espanhol.webp",
          "mobileImage": "assets/home/espanhol-mobile.webp"
        }
      ]
    }
  },
  "slider-layout#carrossel-home-desktop-esp": {
    "props": {
      "itemsPerPage": {
        "desktop": 1,
        "tablet": 1,
        "phone": 1
      },
      "infinite": true,
      "showNavigationArrows": "always",
      "showPaginationDots": "never",
      "blockClass": "carousel",
      "autoplay": {
        "timeout": 5000
      }
    }
  },
  "responsive-layout.desktop#banner-personas-esp": {
    "children": [
      "flex-layout.row#banner-stermaxHealth-personas-esp"
    ]
  },
  "flex-layout.row#banner-stermaxHealth-personas-esp": {
    "props": {
      "blockClass": [
        "personas",
        "personas-inter"
      ],
      "preventHorizontalStretch": true,
      "fullWidth": false
    },
    "children": [
      "rich-text#titulo-profi-esp",
      "image#banner-personas-esp"
    ]
  },
  "rich-text#titulo-profi-esp": {
    "props": {
      "text": "Pure\n health\n expert\n care.",
      "blockClass": "texto-titulo-profi"
    }
  },
  "image#banner-personas-esp": {
    "props": {
      "blockClass": "imagem-personas",
      "src": "assets/home/profi-esp.webp",
      "alt": "Público de Stermax Health",
      "title": "Público de Stermax Health",
      "fullWidth": true
    }
  },
  "responsive-layout.mobile#banner-personas-esp": {
    "children": [
      "flex-layout.row#banner-stermaxHealth-personas-mobile-esp"
    ]
  },
  "flex-layout.row#banner-stermaxHealth-personas-mobile-esp": {
    "props": {
      "blockClass": "personas",
      "fullWidth": false
    },
    "children": [
      "rich-text#titulo-profi-esp-mobile",
      "image#banner-personas-mobile-esp"
    ]
  },
  "rich-text#titulo-profi-esp-mobile": {
    "props": {
      "text": "Pure health expert care.",
      "blockClass": "texto-titulo-profi-mobile"
    }
  },
  "image#banner-personas-mobile-esp": {
    "props": {
      "blockClass": "imagem-personas",
      "src": "assets/home/profi-eng.webp",
      "alt": "Público de Stermax Health",
      "title": "Público de Stermax Health",
      "fullWidth": true
    }
  },
  "flex-layout.row#linha-line-esp": {
    "props": {
      "blockClass": "linha-line",
      "fullWidth": false
    },
    "children": [
      "rich-text#line-esp"
    ]
  },
  "rich-text#line-esp": {
    "props": {
      "text": "",
      "blockClass": "line"
    }
  },
  "responsive-layout.mobile#deals-mobile-esp": {
    "children": [
      "flex-layout.row#deals-mobile-linha1-esp",
      "flex-layout.row#deals-mobile-linha2-esp"
    ]
  },
  "flex-layout.row#deals-mobile-linha1-esp": {
    "props": {
      "blockClass": "deals-mobile-row"
    },
    "children": [
      "flex-layout.col#linha1-coluna1-esp",
      "flex-layout.col#linha1-coluna2-esp",
      "flex-layout.col#linha1-coluna3-esp"
    ]
  },
  "flex-layout.col#linha1-coluna1-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal1",
      "rich-text#deal1-esp"
    ]
  },
  "flex-layout.col#linha1-coluna2-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal2",
      "rich-text#deal2-esp"
    ]
  },
  "flex-layout.col#linha1-coluna3-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal3",
      "rich-text#deal3-esp"
    ]
  },
  "flex-layout.row#deals-mobile-linha2-esp": {
    "props": {
      "blockClass": "deals-mobile-row"
    },
    "children": [
      "flex-layout.col#linha2-coluna1-esp",
      "flex-layout.col#linha2-coluna2-esp",
      "flex-layout.col#linha2-coluna3-esp"
    ]
  },
  "flex-layout.col#linha2-coluna1-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal4",
      "rich-text#deal4-esp"
    ]
  },
  "flex-layout.col#linha2-coluna2-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal5",
      "rich-text#deal5-esp"
    ]
  },
  "flex-layout.col#linha2-coluna3-esp": {
    "props": {
      "blockClass": "deals-mobile-coluna"
    },
    "children": [
      "image#deal6",
      "rich-text#deal6-esp"
    ]
  },
  "flex-layout.row#banner-nao-comprometa-saude-esp": {
    "props": {
      "blockClass": "linha-nao-comprometa-saude",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.col#coluna-naocomprometa-coluna1-esp",
      "flex-layout.col#coluna-naocomprometa-coluna2-esp"
    ]
  },
  "flex-layout.col#coluna-naocomprometa-coluna1-esp": {
    "props": {
      "blockClass": "coluna-naocomprometa-coluna1",
      "width": "50%"
    },
    "children": [
      "image#banner-nao-comprometa-imagem-esp"
    ]
  },
  "image#banner-nao-comprometa-imagem-esp": {
    "props": {
      "blockClass": "banner-nao-comprometa-imagem",
      "src": "assets/home/banner-modelos/img-nao-comprometa.webp",
      "alt": "Imagen usando autoclave",
      "title": "Imagen usando autoclave"
    }
  },
  "flex-layout.col#coluna-naocomprometa-coluna2-esp": {
    "props": {
      "blockClass": "coluna-naocomprometa-coluna2",
      "preventVerticalStretch": true,
      "width": "50%"
    },
    "children": [
      "rich-text#titulo-gatilho-medo-esp",
      "rich-text#subtitulo-gatilho-medo-esp",
      "link#garanta-tranquilidade-esp"
    ]
  },
  "rich-text#titulo-gatilho-medo-esp": {
    "props": {
      "blockClass": "texto-titulo-gatilho-medo",
      "text": "¡No comprometas la salud de tus pacientes y el futuro de tu clínica!"
    }
  },
  "rich-text#subtitulo-gatilho-medo-esp": {
    "props": {
      "blockClass": "texto-subtitulo-gatilho-medo",
      "text": "Sin una esterilización adecuada, aumenta el riesgo de contaminación y enfermedades. Además, no cumplir con las normas de ANVISA puede provocar el cierre de tu consultorio o clínica, poniendo en riesgo tu carrera y tu reputación."
    }
  },
  "link#garanta-tranquilidade-esp": {
    "props": {
      "blockClass": "link-garanta-tranquilidade-internacional",
      "href": "mailto:silmara.mafra@grupomfm.com.br?subject=Consulta%20desde%20el%20sitio%20web&body=Hola,%20me%20gustar%C3%ADa%20recibir%20m%C3%A1s%20informaci%C3%B3n%20sobre%20los%20productos%20disponibles%20en%20el%20sitio.",
      "target": "_blank",
      "rel": "noopener noreferrer"
    },
    "children": [
      "rich-text#titulo-banner-segundo-esp"
    ]
  },
  "rich-text#titulo-banner-segundo-esp": {
    "props": {
      "text": "¡GARANTIZA LA TRANQUILIDAD QUE TUS PACIENTES Y TU EQUIPO MERECEN!",
      "blockClass": "titulo-banner-secundario"
    }
  },
  "flex-layout.row#tipos-autoclaves-home-esp": {
    "props": {
      "blockClass": "linha-tipos-autoclaves-home",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.row#titulo-tipo-home-esp",
      "flex-layout.row#modelos-tipo-home-esp"
    ]
  },
  "flex-layout.row#titulo-tipo-home-esp": {
    "props": {
      "blockClass": "linha-titulo-tipo-home",
      "colSizing": "auto"
    },
    "children": [
      "rich-text#titulo-tipos-home-esp",
      "rich-text#subtitulo-tipos-home-esp"
    ]
  },
  "rich-text#titulo-tipos-home-esp": {
    "props": {
      "blockClass": "titulo-tipos-home",
      "text": "Tecnología, bioseguridad y eficiencia en cada ciclo."
    }
  },
  "rich-text#subtitulo-tipos-home-esp": {
    "props": {
      "blockClass": "subtitulo-tipos-home",
      "text": "Elige la autoclave perfecta para tu especialidad."
    }
  },
  "flex-layout.row#modelos-tipo-home-esp": {
    "props": {
      "blockClass": "linha-modelos-tipo-home"
    },
    "children": [
      "link#coluna-21-litros-esp",
      "link#coluna-30-litros-esp",
      "link#coluna-42-litros-esp",
      "link#coluna-60-litros-esp",
      "link#coluna-75-litros-esp",
      "link#coluna-75vertical-litros-esp"
    ]
  },
