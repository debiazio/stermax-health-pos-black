  "rich-text#titulo21litros-esp": {
    "props": {
      "blockClass": "titulo-modelos",
      "text": "21 litros"
    }
  },
  "rich-text#titulo30litros-esp": {
    "props": {
      "blockClass": "titulo-modelos",
      "text": "30 litros"
    }
  },
  "rich-text#titulo42litros-esp": {
    "props": {
      "blockClass": "titulo-modelos",
      "text": "42 litros"
