  "rich-text#subtitulo21litros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Mayor capacidad, perfecta para profesionales que realizan múltiples atenciones y tienen instrumentos variados."
    }
  },
  "rich-text#subtitulo30litros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Versátil: cubre alta demanda de instrumental y está diseñada para manejar cargas intermedias con eficiencia."
    }
  },
  "rich-text#subtitulo42litros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Ideal para clínicas con alta rotación de materiales."
    }
  },
  "rich-text#subtitulo60litros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Robustez para hospitales y laboratorios: capacidad superior y mayor espacio."
    }
  },
  "rich-text#subtitulo75litros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Nuestra autoclave de mayor capacidad, diseñada para máxima eficiencia, grandes volúmenes y ciclos intensivos."
    }
  },
  "rich-text#subtitulo75verticallitros-esp": {
    "props": {
      "blockClass": "subtitulo-modelos",
      "text": "Modelo de autoclave vertical, exclusivo en el mercado."
    }
  },
