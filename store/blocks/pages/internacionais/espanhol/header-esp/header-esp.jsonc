{
  "sticky-layout#header-esp": {
    "props": {
      "position": "TOP",
      "blockClass": "sticky-header-internacional"
    },
    "children": [
      "flex-layout.row#linhasuperior-home-esp",
      "flex-layout.row#linha-header-esp"
    ]
  },

  "flex-layout.row#linha-header-esp": {
    "props": {
      "blockClass": "linha-header-eng",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.col#colunaesquerda-header-esp",
      "flex-layout.col#colunacentral-header-esp",
      "flex-layout.col#colunadireita-header-esp"
    ]
  },

  "flex-layout.row#linhasuperior-home-esp": {
    "props": {
      "fullWidth": true,
      "blockClass": ["topo-1-header", "topo-1-header-esp"]
    },
    "children": [
      "rich-text#textosuperior-home-esp"
    ]
  },

  "rich-text#textosuperior-home-esp": {
    "props": {
      "blockClass": "rich-text-topo",
      "text": "Seguridad, tecnología y confianza: descubre por qué Stermax Health es la elección correcta para los profesionales de la salud"
    }
  },

  "flex-layout.col#colunaesquerda-header-esp": {
    "props": {
      "blockClass": ["colunas-header", "coluna-esquerda-header-esp"]
    },
    "children": [
      "link#quem-somos-esp"
    ]
  },

  "link#quem-somos-esp": {
    "props": {
      "blockClass": "link-quemsomos-internacional",
      "label": "Quiénes somos",
      "href": "/esp/quienes-somos"
    }
  },

  "flex-layout.col#colunacentral-header-esp": {
    "props": {
      "blockClass": ["colunas-header", "coluna-central-header-esp"]
    },
    "children": [
      "logo#desktop-esp"
    ]
  },

  "logo#desktop-esp": {
    "props": {
      "blockClass": "logo",
      "title": "Logo",
      "href": "/esp/",
      "url": "assets/header/novo-logo-stxh.png",
      "width": "157",
      "height": "48"
    }
  },

  "flex-layout.col#colunadireita-header-esp": {
    "props": {
      "blockClass": ["colunas-header", "coluna-direita-header-esp"]
    },
    "children": [
      "overlay-trigger#languages-esp"
    ]
  },
  "overlay-trigger#languages-esp":{
    "children": [
      "image#lang-switcher-icon",
      "overlay-layout#esp"
    ]
  },
  "overlay-layout#esp": {
    "props": {
      "placement": "bottom",
      "blockClass": "overlay"
    },
    "children": [
      "rich-text#ttiulo-language-switcher",
      "link#acesso-english-page",
      "link#acesso-portugues-page"
    ]
  },
  "link#acesso-portugues-page":{
    "props": {
      "blockClass": "link-acesso-language-alterator",
      "label": "Português",
      "href": "/"
    }
  }
}
