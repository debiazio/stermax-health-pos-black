    ]
  },
  "disclosure-state-indicator#pq-ecolher-stx-esp": {
    "props": {
      "Show": "icon-caret#down-pq-ecolher-stx-esp",
      "Hide": "icon-caret#up-pq-ecolher-stx-esp"
    }
  },
  "icon-caret#down-pq-ecolher-stx-esp": {
    "props": {
      "blockClass": "baixo",
      "orientation": "down"
    }
  },
  "icon-caret#up-pq-ecolher-stx-esp": {
    "props": {
      "blockClass": "cima-pq-ecolher-stx",
      "orientation": "up"
