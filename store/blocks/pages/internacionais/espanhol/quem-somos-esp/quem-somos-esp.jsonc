    ]
  },
  "rich-text#trigger-maisde30anos-esp": {
    "props": {
      "blockClass": [
        "texto-trigger",
        "texto-trigger-30anos"
      ],
      "text": "30 años de experiencia"
    }
  },
  "rich-text#trigger-certificacao-iso-anvisa-esp": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Certificación ISO y ANVISA"
    }
  },
  "rich-text#trigger-assistencia-tecnica-esp": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Asistencia técnica"
    }
  },
  "rich-text#trigger-loja-oficial-esp": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Tienda oficial"
    }
  },
  "rich-text#trigger-equipe-de-consultoria-esp": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Equipo de consultoría"
    }
  },
  "rich-text#trigger-infra-completa-esp": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Infraestructura completa"
    }
  },
  "rich-text#content-maisde30anos-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "Más de 30 años de experiencia en la fabricación de autoclaves. Tres décadas en el mercado garantizan un dominio total de los procesos de esterilización, dando como resultado equipos confiables, modernos y diseñados para la rutina profesional."
    }
  },
  "rich-text#content-certificacao-iso-anvisa-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "Certificación internacional ISO 13485 y registro en ANVISA. Seguir rigurosos estándares de calidad y seguridad demuestra que cada producto se desarrolla conforme a normas internacionales y en pleno cumplimiento de los requisitos sanitarios brasileños."
    }
  },
  "rich-text#content-assistencia-tecnica-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "La mayor red de asistencia técnica del país, con profesionales capacitados distribuidos en varias regiones. Stermax ofrece soporte rápido, mantenimiento ágil y disponibilidad de piezas originales, reduciendo tiempos de inactividad y garantizando la longevidad de los equipos."
    }
  },
  "rich-text#content-loja-oficial-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "Tienda oficial, directa de fábrica: precio justo y atención especializada. Al comprar directamente al fabricante, tienes la seguridad de adquirir un equipo nuevo, original y en condiciones más ventajosas, además de recibir orientación personalizada desde la elección hasta la posventa."
    }
  },
  "rich-text#content-equipe-de-consultoria-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "Equipo de consultoría técnica dedicada, especialistas listos para orientarte sobre el uso correcto, el mantenimiento preventivo y las mejores prácticas de esterilización, ayudándote a obtener el máximo rendimiento y seguridad en tu rutina diaria."
    }
  },
  "rich-text#content-infra-completa-esp": {
    "props": {
      "blockClass": "texto-content",
      "text": "Infraestructura completa de atención y soporte. Stermax reúne en un solo ecosistema: consultoría técnica, atención al cliente, posventa calificada y una sólida red de asistencia técnica, todo estructurado para garantizar una experiencia completa y sin complicaciones."
    }
  },
  "flex-layout.row#seja-bem-vindo-esp": {
    "props": {
      "blockClass": "linha-seja-bemvindo",
      "fullWidth": true
    },
    "children": [
      "rich-text#titulo-seja-bemvindo-esp",
      "rich-text#subtitulo-seja-bemvindo-esp"
    ]
  },
  "rich-text#titulo-seja-bemvindo-esp": {
    "props": {
      "blockClass": "titulo-texto-seja-bemvindo",
      "text": "Bienvenido a **Stermax Health**"
    }
  },
  "rich-text#subtitulo-seja-bemvindo-esp": {
    "props": {
      "blockClass": "subtitulo-texto-seja-bemvindo",
      "text": "La Stermax que ya conoces, ahora enfocada en el sector de la salud"
    }
  }
}
