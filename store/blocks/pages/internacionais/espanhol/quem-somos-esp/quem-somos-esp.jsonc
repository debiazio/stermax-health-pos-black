{
  "store.custom#quem-somos-espanhol": {
    "parent": {
      "header": "header#empty",
      "footer": "footer#empty"
    },
    "children": [
      "sticky-layout#header-esp",
      "flex-layout.row#linha-quem-somos-esp",
      "flex-layout.row#linha-selos-quem-somos-esp",
      "flex-layout.row#linha-nosso-proposito-esp",
      "responsive-layout.desktop#colunas-biosseguranca-esp",
      "responsive-layout.mobile#colunas-biosseguranca-esp",
      "flex-layout.row#titulo-pq-ecolher-esp",
      "flex-layout.row#disclosure-layout-quem-somos-esp",
      "flex-layout.row#seja-bem-vindo-esp",
      "responsive-layout.desktop#footer-esp",
      "responsive-layout.mobile#footer-esp"
    ]
  },
  "flex-layout.row#linha-quem-somos-esp": {
    "props": {
      "blockClass": "linha-quem-somos",
      "colSizing": "auto",
      "fullWidth": false
    },
    "children": [
      "rich-text#titulo-quem-somos-esp",
      "rich-text#texto-quem-somos-esp"
    ],
    "title": "Banner sobre nosotros"
  },
  "rich-text#titulo-quem-somos-esp": {
    "props": {
      "text": "Sobre Nosotros",
      "blockClass": "titulo-quem-somos"
    },
    "title": "Título sobre nosotros"
  },
  "rich-text#texto-quem-somos-esp": {
    "props": {
      "text": "Con sede en Pinhais, Paraná, y presencia en todo el país, ofrecemos una experiencia de compra directa de fábrica, combinando calidad, seguridad y confianza para clínicas, consultorios, hospitales y laboratorios. A lo largo de su trayectoria, Stermax se ha consolidado como una referencia en el sector, invirtiendo continuamente en innovación y excelencia para transformar la rutina de esterilización.",
      "blockClass": "texto-quem-somos",
      "textAlignment": "CENTER"
    },
    "title": "Texto sobre nosotros"
  },
  "flex-layout.row#linha-selos-quem-somos-esp": {
    "props": {
      "blockClass": ["linha-selos-quem-somos", "linha-selos-quem-somos-inter"],
      "colSizing": "auto"
    },
    "children": [
      "responsive-layout.desktop#banner-quem-somos-esp",
      "responsive-layout.mobile#banner-quem-somos-esp"
    ]
  },
  "responsive-layout.desktop#banner-quem-somos-esp": {
    "children": [
      "flex-layout.col#coluna-selos-desde-quem-somos-esp",
      "flex-layout.col#coluna-selos-300mil-quem-somos-esp",
      "flex-layout.col#coluna-selos-lider-quem-somos-esp",
      "flex-layout.col#coluna-selos-nacional-quem-somos-esp"
    ]
  },
  "flex-layout.col#coluna-selos-desde-quem-somos-esp": {
    "props": {
      "blockClass": "coluna-selos"
    },
    "children": [
      "image#icone-desde",
      "image#img-texto-desde"
    ]
  },
  "flex-layout.col#coluna-selos-300mil-quem-somos-esp": {
    "props": {
      "blockClass": "coluna-selos"
    },
    "children": [
      "image#icone-300mil",
      "image#img-texto-300mil"
    ]
  },
  "flex-layout.col#coluna-selos-lider-quem-somos-esp": {
    "props": {
      "blockClass": "coluna-selos"
    },
    "children": [
      "image#icone-lider",
      "image#img-texto-lider"
    ]
  },
  "flex-layout.col#coluna-selos-nacional-quem-somos-esp": {
    "props": {
      "blockClass": "coluna-selos"
    },
    "children": [
      "image#icone-nacional",
      "image#img-texto-nacional"
    ]
  },
  "image#icone-desde": {
    "props": {
      "src": "assets/quem-somos/desde-91.webp",
      "alt": "Imagen de sello",
      "blockClass": "icone-selos"
    }
  },
  "image#img-texto-desde": {
    "props": {
      "src": "assets/quem-somos/desde-91-texto.webp",
      "alt": "Imagen de sello",
      "blockClass": [
        "icone-selos",
        "icone-selos-menor"
      ]
    }
  },
  "image#icone-300mil": {
    "props": {
      "src": "assets/quem-somos/vendidas.webp",
      "alt": "Imagen de sello",
      "blockClass": [
        "icone-selos"
      ]
    }
  },
  "image#img-texto-300mil": {
    "props": {
      "src": "assets/quem-somos/300mil-texto.webp",
      "alt": "Imagen de sello",
      "blockClass": [
        "icone-selos"
      ]
    }
  },
  "image#icone-lider": {
    "props": {
      "src": "assets/quem-somos/lider.webp",
      "alt": "Imagen de sello",
      "blockClass": [
        "icone-selos",
        "icone-selos-menor"
      ]
    }
  },
  "image#img-texto-lider": {
    "props": {
      "src": "assets/quem-somos/lider-texto.webp",
      "alt": "Imagen de sello",
      "blockClass": "icone-selos"
    }
  },
  "image#icone-nacional": {
    "props": {
      "src": "assets/quem-somos/fab-nacional.webp",
      "alt": "Imagen de sello",
      "blockClass": "icone-selos"
    }
  },
  "image#img-texto-nacional": {
    "props": {
      "src": "assets/quem-somos/fab-nacional-texto.webp",
      "alt": "Imagen de sello",
      "blockClass": "icone-selos"
    }
  },
  "responsive-layout.mobile#banner-quem-somos-esp": {
    "children": [
      "flex-layout.row#linha1-selos-mobile-esp",
      "flex-layout.row#linha2-selos-mobile-esp"
    ]
  },
  "flex-layout.row#linha1-selos-mobile-esp": {
    "props": {
      "blockClass": "linha-selos-mobile",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.col#coluna-selos-desde-quem-somos-esp",
      "flex-layout.col#coluna-selos-lider-quem-somos-esp"
    ]
  },
  "flex-layout.row#linha2-selos-mobile-esp": {
    "props": {
      "blockClass": "linha-selos-mobile",
      "colSizing": "auto"
    },
    "children": [
      "flex-layout.col#coluna-selos-300mil-quem-somos-esp",
      "flex-layout.col#coluna-selos-nacional-quem-somos-esp"
    ]
  },
  "flex-layout.row#linha-nosso-proposito-esp": {
    "props": {
      "blockClass": "linha-nosso-proposito",
      "colSizing": "auto"
    },
    "children": [
      "rich-text#titulo-nosso-proposito-esp",
      "rich-text#texto-nosso-proposito-esp"
    ]
  },
  "rich-text#titulo-nosso-proposito-esp": {
    "props": {
      "blockClass": "titulo-nosso-proposito",
      "text": "Nuestro propósito"
    }
  },
  "rich-text#texto-nosso-proposito-esp": {
    "props": {
      "blockClass": "texto-nosso-proposito",
      "text": "Nuestra misión es facilitar el acceso a las soluciones de Stermax con la máxima conveniencia y credibilidad. Aquí encontrarás todas las líneas de autoclaves horizontales, con soporte técnico dedicado, manual de operación, compra segura y garantía de fábrica. Stermax Health es la tienda oficial de Stermax, una marca líder en equipos de esterilización desde hace más de 30 años en el mercado. Fuimos creados para atender con excelencia a los profesionales de la salud que exigen el más alto estándar en bioseguridad, ofreciendo autoclaves horizontales y otros equipos certificados, fabricados en Brasil con calidad internacional de producción."
    }
  },
  "responsive-layout.desktop#colunas-biosseguranca-esp": {
    "children": [
      "flex-layout.row#compromisso-biosseguranca-esp"
    ]
  },
  "flex-layout.row#compromisso-biosseguranca-esp": {
    "props": {
      "blockClass": "linha-compromisso-bioss"
    },
    "children": [
      "flex-layout.col#coluna-textos-biosseguranca-esp",
      "flex-layout.col#coluna-imagem-biosseguranca-esp"
    ]
  },
  "flex-layout.col#coluna-textos-biosseguranca-esp": {
    "props": {
      "blockClass": "biosseguranca-colunas-textos",
      "preventVerticalStretch": true,
      "width": "60%"
    },
    "children": [
      "rich-text#titulo-biosseguranca-esp",
      "rich-text#texto-biosseguranca-esp"
    ]
  },
  "rich-text#titulo-biosseguranca-esp": {
    "props": {
      "blockClass": "titulo-biosseguranca",
      "text": "Nuestro compromiso con la **Bioseguridad**"
    }
  },
  "rich-text#texto-biosseguranca-esp": {
    "props": {
      "blockClass": "texto-biosseguranca",
      "text": "Stermax fue creada por profesionales que entienden la complejidad y la importancia de la bioseguridad en la rutina de la salud. Cada equipo se desarrolla para proporcionar esterilización confiable, durabilidad y eficiencia, protegiendo a profesionales y pacientes."
    }
  },
  "flex-layout.col#coluna-imagem-biosseguranca-esp": {
    "props": {
      "blockClass": "coluna-imagem-bioss",
      "width": "40%"
    },
    "children": [
      "image#img-biosseguranca"
    ]
  },
  "image#img-biosseguranca": {
    "props": {
      "blockClass": "image-biosseguranca",
      "alt": "Mujer bioseguridad",
      "src": "assets/quem-somos/desktop/bioseguranca-desktop.webp"
    }
  },
  "responsive-layout.mobile#colunas-biosseguranca-esp": {
    "children": [
      "flex-layout.row#compromisso-biosseguranca-mobile-esp"
    ]
  },
  "flex-layout.row#compromisso-biosseguranca-mobile-esp": {
    "props": {
      "blockClass": "linha-compromisso-biosseguranca-mobile"
    },
    "children": [
      "rich-text#titulo-biosseguranca-mobile-esp",
      "rich-text#texto-biosseguranca-esp",
