  "rich-text#titulo-gatilho-medo-eng": {
    "props": {
      "blockClass": "texto-titulo-gatilho-medo",
      "text": "Do not compromise the health of your patients and the future of your clinic!"
    }
  },
  "rich-text#subtitulo-gatilho-medo-eng": {
    "props": {
      "blockClass": "texto-subtitulo-gatilho-medo",
      "text": "Without proper sterilization, the risk of contamination and disease increases. In addition, failing to comply with ANVISA regulations can result in your office or clinic being shut down, putting your career and reputation at risk!"
    }
  },
  "link#garanta-tranquilidade-eng": {
    "props": {
      "blockClass": "link-garanta-tranquilidade-internacional",
      "href": "mailto:silmara.mafra@grupomfm.com.br?subject=Inquiry%20from%20the%20website&body=Hello,%0A%0AI%20would%20like%20to%20receive%20more%20information%20about%20the%20products%20available%20on%20the%20website.%0A%0AThank%20you.",
