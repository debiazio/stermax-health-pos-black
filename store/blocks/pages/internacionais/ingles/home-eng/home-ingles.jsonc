{
  "store.custom#home-ingles": {
    "parent": {
      "header": "header#empty",
      "footer": "footer#empty"
    },
    "blocks": [
      "sticky-layout#header-eng",
      "list-context.image-list#carrossel-home-desktop-eng",
      "responsive-layout.desktop#banner-personas-eng",
      "responsive-layout.mobile#banner-personas-eng",
      "flex-layout.row#linha-line-eng",
      "__fold__",
      // "flex-layout.row#shelf-eng",
      "responsive-layout.mobile#deals-mobile-eng",
      "flex-layout.row#texto-direciona-eng",
      "flex-layout.row#deals-eng",
      "flex-layout.row#banner-nao-comprometa-saude-eng",
      "flex-layout.row#tipos-autoclaves-home-eng",
      "flex-layout.row#linha-line-eng",
      // "flex-layout.row#shelf-acessorios-eng",
      "flex-layout.row#ultima-section-eng",
      "responsive-layout.desktop#footer-eng",
      "responsive-layout.mobile#footer-eng"
    ]
  },
  "flex-layout.row#texto-direciona-eng": {
    "props": {
      "blockClass": "linha-texto-direciona-eng"
    },
    "children": [
      "responsive-layout.desktop#banner-catolog-eng",
      "responsive-layout.mobile#banner-catolog-eng"

    ]
  },
  "responsive-layout.desktop#banner-catolog-eng":{
    "children": [
      "image#catalogo-eng"
    ]
  },
  "responsive-layout.mobile#banner-catolog-eng":{
    "children": [
      "image#catalogo-eng-mobile"
    ]
  },
  "image#catalogo-eng": {
    "props": {
      "blockClass": "imag-catalog",
      "src": "assets/home/ingles/catalogo-eng.webp",
      "link": {
        "url": "https://wa.me/5541999710062"
      }
    }
  },
  "image#catalogo-eng-mobile": {
    "props": {
      "blockClass": "imag-catalog",
      "src": "assets/home/ingles/catalo-eng-mobile.png",
      "link": {
        "url": "https://wa.me/5541999710062"
      }
    }
  },
  "list-context.image-list#carrossel-home-desktop-eng": {
    "children": [
      "slider-layout#carrossel-home-desktop-eng"
    ],
    "props": {
      "fullWidth": true,
      "height": 486,
      "width": 1300,
      "maxWidth": 1300,
      "preload": true,
      "images": [
        {
          "image": "assets/home/espanhol/STHX - BANNER DESK PLENA 42.webp",
          "mobileImage": "assets/home/espanhol/STHX - BANNER MOBILE PLENA 42.webp"
        },
        {
          "image": "assets/home/ingles/STHX - BANNER DESK ingles.webp",
          "mobileImage": "assets/home/ingles/STHX - BANNER MOBILE ingles.webp"
        }
      ]
    }
  },
  "slider-layout#carrossel-home-desktop-eng": {
    "props": {
      "itemsPerPage": {
        "desktop": 1,
        "tablet": 1,
        "phone": 1
      },
      "infinite": true,
      "showNavigationArrows": "always",
      "showPaginationDots": "never",
      "blockClass": "carousel",
      "autoplay": {
        "timeout": 5000
      }
    }
  },
  "responsive-layout.desktop#banner-personas-eng": {
    "children": [
      "flex-layout.row#banner-stermaxHealth-personas-eng"
    ]
  },
  "flex-layout.row#banner-stermaxHealth-personas-eng": {
    "props": {
      "blockClass": [
        "personas",
        "personas-inter"
      ],
      "preventHorizontalStretch": true,
      "fullWidth": false
    },
    "children": [
      "rich-text#titulo-profi-eng",
      "image#banner-personas-eng"
    ]
  },
  "rich-text#titulo-profi-eng": {
    "props": {
      "text": "Pure\n health\n expert\n care.",
      "blockClass": "texto-titulo-profi"
    }
  },
  "image#banner-personas-eng": {
    "props": {
      "blockClass": "imagem-personas",
      "src": "assets/home/profi-eng.webp",
      "alt": "StermaxHealth Audience",
      "title": "StermaxHealth Audience",
      "fullWidth": true
    }
  },
  "responsive-layout.mobile#banner-personas-eng": {
    "children": [
      "flex-layout.row#banner-stermaxHealth-personas-mobile-eng"
    ]
  },
  "flex-layout.row#banner-stermaxHealth-personas-mobile-eng": {
    "props": {
      "blockClass": "personas",
      "fullWidth": false
    },
    "children": [
