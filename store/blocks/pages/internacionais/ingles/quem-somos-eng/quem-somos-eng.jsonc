    "props": {
      "blockClass": "content-disclosure-filho"
    },
    "children": [
      "rich-text#content-certificacao-iso-anvisa-eng"
    ]
  },
  "disclosure-content#assistencia-tecnica-eng": {
    "props": {
      "blockClass": "content-disclosure-filho"
    },
    "children": [
      "rich-text#content-assistencia-tecnica-eng"
    ]
  },
  "disclosure-content#loja-oficial-eng": {
    "props": {
      "blockClass": "content-disclosure-filho"
    },
    "children": [
      "rich-text#content-loja-oficial-eng"
    ]
  },
  "disclosure-content#equipe-de-consultoria-eng": {
    "props": {
      "blockClass": "content-disclosure-filho"
    },
    "children": [
      "rich-text#content-equipe-de-consultoria-eng"
    ]
  },
  "disclosure-content#infra-completa-eng": {
    "props": {
      "blockClass": "content-disclosure-filho"
    },
    "children": [
      "rich-text#content-infra-completa-eng"
    ]
  },
  "rich-text#trigger-maisde30anos-eng": {
    "props": {
      "blockClass": [
        "texto-trigger",
        "texto-trigger-30anos"
      ],
      "text": "30 years of experience"
    }
  },
  "rich-text#trigger-certificacao-iso-anvisa-eng": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "ISO and ANVISA certification"
    }
  },
  "rich-text#trigger-assistencia-tecnica-eng": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Technical assistance"
    }
  },
  "rich-text#trigger-loja-oficial-eng": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Official store"
    }
  },
  "rich-text#trigger-equipe-de-consultoria-eng": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Consulting team"
    }
  },
  "rich-text#trigger-infra-completa-eng": {
    "props": {
      "blockClass": "texto-trigger",
      "text": "Complete infrastructure"
    }
  },
  "rich-text#content-maisde30anos-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "More than 30 years of experience in manufacturing autoclaves. Three decades in the market ensure complete mastery of sterilization processes, resulting in reliable, modern equipment designed for professional routines."
    }
  },
  "rich-text#content-certificacao-iso-anvisa-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "International ISO 13485 certification and ANVISA registration. Following rigorous quality and safety standards proves that each product is developed according to international standards and in full compliance with Brazilian health requirements."
    }
  },
  "rich-text#content-assistencia-tecnica-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "The largest technical assistance network in the country, with trained professionals distributed across several regions. Stermax offers fast support, agile maintenance, and availability of original parts, reducing downtime and ensuring equipment longevity."
    }
  },
  "rich-text#content-loja-oficial-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "Official store, direct from the factory – fair price and specialized service. By buying directly from the manufacturer, you have the security of purchasing new, original equipment under more advantageous conditions, as well as receiving personalized guidance from selection to after-sales."
    }
  },
  "rich-text#content-equipe-de-consultoria-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "Dedicated technical consulting team, specialists ready to guide you on proper use, preventive maintenance, and sterilization best practices, helping you achieve maximum performance and safety in your daily routine."
    }
  },
  "rich-text#content-infra-completa-eng": {
    "props": {
      "blockClass": "texto-content",
      "text": "Complete service and support infrastructure. Stermax brings together in a single ecosystem: technical consulting, customer service, qualified after-sales, and a robust technical assistance network – all structured to ensure a complete and hassle-free experience."
    }
  },
  "flex-layout.row#seja-bem-vindo-eng": {
    "props": {
      "blockClass": "linha-seja-bemvindo",
      "fullWidth": true
    },
    "children": [
      "rich-text#titulo-seja-bemvindo-eng",
      "rich-text#subtitulo-seja-bemvindo-eng"
    ]
  },
  "rich-text#titulo-seja-bemvindo-eng": {
    "props": {
      "blockClass": "titulo-texto-seja-bemvindo",
      "text": "Welcome to **Stermax Health**"
    }
  },
  "rich-text#subtitulo-seja-bemvindo-eng": {
    "props": {
      "blockClass": "subtitulo-texto-seja-bemvindo",
      "text": "The Stermax you already know, now focused on the healthcare sector"
    }
  }
}
